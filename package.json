    "@types/fabric": "^5.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "fabric": "^7.2.0",
    "next": "^14.2.35",
    "open": "^11.0.0",
    "openai": "^6.33.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",

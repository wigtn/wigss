{
  "name": "wigss",
  "version": "0.1.2",
  "description": "WIGSS (Style Shaper) — visual code refactoring tool with always-on AI agent",
  "license": "MIT",
  "author": "Team WIGSS (WIGTN Crew)",
  "repository": {
    "type": "git",
    "url": "https://github.com/wigtn/wigss"
  },

# ============================================
# WIGSS Environment Variables
# ============================================
# Copy this file to .env.local and fill in values:
#   cp .env.example .env.local
# ============================================

# --- AI API (Required) ---

# OpenAI API Key (single key for all AI features)
#   GPT-4o  → real-time tracking (detect, suggest, feedback, chat)
#   GPT-5.4 → code refactoring + self-verification
OPENAI_API_KEY=sk-xxx

# --- Ports (Optional, defaults shown) ---

# WIGSS editor port
WIGSS_PORT=4000

# WebSocket server port (agent communication)
WS_PORT=4001

# Target dev server port (the page being edited)
TARGET_PORT=3001

# --- Paths (Optional, auto-detected from cwd) ---

# Project source path (auto-detected from cwd when using npx wigss)
# SOURCE_PATH=/path/to/your/project/src

# --- Mode (Optional) ---

# Set to "true" to use cached demo data (no AI/Playwright calls)
# DEMO_MODE=false

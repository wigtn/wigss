{
  "name": "wigss",
  "version": "0.1.0",
  "description": "WIGSS (Style Shaper) — visual code refactoring tool with always-on AI agent",
  "private": true,
  "bin": {
    "wigss": "./bin/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"next dev --port 4000\" \"pnpm --filter demo-target dev\"",

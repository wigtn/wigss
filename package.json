{
  "name": "wigss",
  "version": "0.1.4",
  "description": "WIGSS (Style Shaper) by WIGTN Crew — drag UI components and the source code rewrites itself. Visual code refactoring CLI with always-on AI agent. Supports Tailwind CSS, CSS Modules, and inline styles.",
  "license": "Apache-2.0",
  "author": "Harrison Kim <hyeongseob91@gmail.com> (WIGTN Crew)",
  "contributors": [
    "Harrison Kim",
    "Jinmo Kim"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wigtn/wigss"
  },
  "homepage": "https://github.com/wigtn/wigss#readme",
  "bugs": {
    "url": "https://github.com/wigtn/wigss/issues"
  },
  "type": "module",
  "main": "./bin/cli.js",
  "bin": {
    "wigss": "./bin/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"next dev --port 4000\" \"pnpm --filter demo-target dev\"",
    "build": "next build",
    "start": "next start --port 4000",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "wigss",
    "wigtn",
    "wigtn-crew",
    "style-shaper",
    "ai",
    "ai-agent",
    "agent",
    "visual-editor",
    "visual-code-editor",
    "refactoring",
    "code-refactoring",
    "tailwind",
    "tailwind-css",
    "css-modules",
    "drag-and-drop",
    "ui-editor",
    "component-editor",
    "nextjs",
    "react",
    "frontend-tools",
    "developer-tools",
    "devtools",
    "cli",
    "design-to-code",
    "low-code",
    "live-preview",
    "source-code-rewrite",
    "openai",
    "gpt-4o"
  ],
  "packageManager": "pnpm@10.28.1",
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.27",
    "commander": "^14.0.3",
    "concurrently": "^9.2.1",
    "next": "^14.2.35",
    "open": "^11.0.0",
    "openai": "^6.33.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-next": "16.2.1",
    "vitest": "^4.1.2"
  }
